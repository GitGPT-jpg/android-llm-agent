# ─────────────────────────────────────────────────────────────────────────────
# Android LLM Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: mock | openai | claude | deepseek
AI_MODE=mock

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: override API base URL (e.g. for a proxy or compatible endpoint)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

